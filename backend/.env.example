# =============================
# Backend environment template
# 复制为 .env 后按实际环境填写，切勿提交真实密钥
# 注意：Spring Boot 默认不会自动读取 .env，需由 shell/systemd/docker 注入
# 用法：
#   cd backend
#   . .\scripts\load-env.ps1
#   .\mvnw.cmd spring-boot:run
# 或：
#   .\scripts\start-dev.ps1
#   .\scripts\start-dev.ps1 -Profile dev-postgres
# Linux:
#   cd backend
#   source ./scripts/load-env.sh
#   ./scripts/start-dev.sh --profile dev-postgres
# =============================

# profile
SPRING_PROFILES_ACTIVE=dev-postgres
APP_PRIMARY_DATASOURCE=postgresql

# server
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# postgres
POSTGRES_URL=jdbc:postgresql://localhost:5432/interview_os
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=replace_me

# mysql (当前多数据源配置会创建该数据源，建议也提供可用值)
MYSQL_URL=jdbc:mysql://localhost:3306/interview_os?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC
MYSQL_USERNAME=root
MYSQL_PASSWORD=replace_me

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# openai
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.7

# jpa
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true
DB_TIME_ZONE=UTC

# logging
APP_LOG_LEVEL=INFO
SPRING_AI_LOG_LEVEL=INFO
SPRING_WEB_LOG_LEVEL=INFO
